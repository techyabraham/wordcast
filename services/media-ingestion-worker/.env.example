# ── media-ingestion-worker environment variables ──────────────────────────────
# Copy to .env and fill in real values before running.
# Prerequisites: ffmpeg and yt-dlp must be on PATH.

# PostgreSQL connection string
DATABASE_URL=postgresql://wordcast:wordcast@localhost:5432/wordcast?schema=public

# Redis connection string (used for BullMQ queue: media-ingestion)
REDIS_URL=redis://localhost:6379

# OpenAI API key — used for Whisper audio transcription
OPENAI_API_KEY=sk-...

# Cloudflare R2 object storage (stores downloaded audio files)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=wordcast-media
R2_PUBLIC_URL=https://your-r2-public-endpoint

# Node environment
NODE_ENV=development
