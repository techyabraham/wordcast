# ── media-worker environment variables ────────────────────────────────────────
# Copy to .env and fill in real values before running.

# PostgreSQL connection string
DATABASE_URL=postgresql://wordcast:wordcast@localhost:5432/wordcast?schema=public

# Redis connection string (used for BullMQ queue)
REDIS_URL=redis://localhost:6379

# Node environment
NODE_ENV=development
