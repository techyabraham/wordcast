# ── search-worker environment variables ───────────────────────────────────────
# Copy to .env and fill in real values before running.

# PostgreSQL connection string
DATABASE_URL=postgresql://wordcast:wordcast@localhost:5432/wordcast?schema=public

# Redis connection string (used for BullMQ queue: search-indexing)
REDIS_URL=redis://localhost:6379

# Typesense configuration
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=xyz-wordcast-typesense-key

# Node environment
NODE_ENV=development
