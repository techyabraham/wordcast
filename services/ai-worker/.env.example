# ── ai-worker environment variables ───────────────────────────────────────────
# Copy to .env and fill in real values before running.

# PostgreSQL connection string
DATABASE_URL=postgresql://wordcast:wordcast@localhost:5432/wordcast?schema=public

# Redis connection string (used for BullMQ queues: ai-processing, search-indexing)
REDIS_URL=redis://localhost:6379

# OpenAI API key — used for Whisper transcription and GPT metadata generation
OPENAI_API_KEY=sk-...

# Node environment
NODE_ENV=development
