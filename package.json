{
  "name": "wordcast",
  "private": true,
  "version": "0.1.0",
  "description": "Wordcast monorepo",
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @wordcast/api dev",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "pnpm --filter @wordcast/api prisma:generate",
    "db:migrate": "pnpm --filter @wordcast/api prisma:migrate",
    "db:seed": "pnpm --filter @wordcast/api prisma:seed",
    "compose:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "compose:down": "docker compose -f infrastructure/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.1"
  }
}
